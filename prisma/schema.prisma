generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Gender {
  MALE
  FEMALE
}

enum Relationship {
  PARENT
  GUARDIAN
  SIBLING
  OTHER
}

enum Role {
  SERVICE_PROVIDER
  CAREGIVER
}

enum CaregiverType {
  GROUP
  INDIVIDUAL
}

enum LicenseStatus {
  ACTIVE
  INACTIVE
}

enum EducationLevel {
  BASIC
  HIGHSCHOOL
  TERTIARY
}

enum IdType {
  NATIONAL_ID
  PASSPORT
  DRIVER_LICENSE
  ECOWAS_ID
}

enum SchoolType {
  PUBLIC
  PRIVATE
  SPECIAL_NEEDS

  @@map("schoolType")
}

enum Profession {
  GENERAL_PAEDIATRICIAN
  DEVELOPMENTAL_PAEDIATRICIAN
  PAEDIATRIC_NEUROLOGIST
  NEURODEVELOPMENTAL_PAEDIATRICIAN
  REHABILITATION_PAEDIATRICIAN
  PHYSIOTHERAPIST
  OCCUPATIONAL_THERAPIST
  SPEECH_THERAPIST
  CLINICAL_PSYCHOLOGIST
  DIETITIAN
  PHARMACIST
}

enum FacilityType {
  TERTIARY_TEACHING_HOSPITAL
  REGIONAL_HOSPITAL
  SECONDARY_HEALTH_CARE
  PRIMARY_HEALTHCARE
  CP_HOME
}

enum ProfessionalBody {
  AHPC
  MDC
  PHCG
  PSCG
}

enum AssessmentStatus {
  DRAFT
  COMPLETED
  REVIEWED
}

enum ReferralStatus {
  PENDING
  ACCEPTED
  DECLINED
  COMPLETED
}

enum RehabTaskStatus {
  PENDING
  ASSIGNED
  COMPLETED
}

enum AppointmentStatus {
  PENDING
  APPROVED
  DECLINED
  COMPLETED
  RESCHEDULED

  @@map("appointmentStatus")
}

model User {
  id                  String               @id @default(uuid())
  fullName            String
  email               String?              @unique
  password            String
  phoneNumber         String               @unique
  gender              Gender
  role                Role
  profileImage        String?
  verified            Boolean              @default(false)
  profileCompleted    Boolean              @default(false)
  accountStatus       AccountStatus        @default(ACTIVE)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  address             String?
  digitalAddress      String?
  dateOfBirth         DateTime
  otp                 Otp?
  refreshToken        RefreshToken[]
  passwordResetTokens PasswordResetToken[]

  serviceProvider ServiceProvider?
  caregiver       CareGiver?

  // Community relations
  createdCommunities     Community[]             @relation("CommunityCreator")
  communityMemberships   CommunityMember[]
  communityGroupMembers  CommunityGroupMember[]
  communityMessages      CommunityMessage[]
  communityAnnouncements CommunityAnnouncement[]
  communityInvitations   CommunityInvitation[]
  sentDirectMessages     DirectMessage[]         @relation("DirectMessageSender")
  receivedDirectMessages DirectMessage[]         @relation("DirectMessageReceiver")
  pdfResources           PdfResource[]
  notifications          Notification[]
  pushNotificationTokens PushNotificationToken[] @relation("UserPushTokens")
}

model Otp {
  id         String    @id @default(uuid())
  codeHash   String?
  userId     String    @unique
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime?
  attempts   Int       @default(0)
  requestId  String?
  prefix     String?
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  expiresAt DateTime
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  expiresAt DateTime
  usedAt    DateTime?
}

model ServiceProvider {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  licenseNumber     String?
  licenseImage      String?
  licenseExpiry     DateTime
  licenseIssuedBy   String?
  licenseIssuedDate DateTime
  licenseType       ProfessionalBody
  licenseStatus     LicenseStatus    @default(INACTIVE)
  profession        Profession
  facilityType      FacilityType
  facilityName      String
  facilityAddress   String
  licensePin        String
  experience        Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinicalAssessments       ClinicalAssessment[]       @relation("ProviderAssessments")
  clinicalReferrals         ClinicalReferral[]         @relation("ProviderReferrals")
  incomingReferrals         ClinicalReferral[]         @relation("ReferralRecipients")
  rehabTasks                RehabTask[]
  functionalClassifications FunctionalClassification[]

  appointments   Appointment[]
  availabilities ProviderAvailability[]
  pdfResources   PdfResource[]

  @@map("serviceProvider")
}

model ProviderAvailability {
  id         String          @id @default(uuid())
  providerId String
  provider   ServiceProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  dayOfWeek Int // 0 = Sunday, 1 = Monday ... 6 = Saturday
  startTime String // stored as HH:mm
  endTime   String // stored as HH:mm

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([providerId])
}

model CareGiver {
  id     String        @id @default(uuid())
  type   CaregiverType
  userId String?       @unique
  user   User?         @relation(fields: [userId], references: [id], onDelete: Cascade)

  occupation     String?
  educationLevel EducationLevel?
  idType         IdType?
  idNumber       String?

  nameOfGroup           String?
  locationOfGroup       String?
  groupContact          String?
  groupDigitalAddress   String?
  groupEmail            String?
  managerName           String?   @map("ManagerName")
  managerContact        String?
  verificationDocuments String[]
  isVerified            Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cpPatients CpPatient[]
}

model CpPatient {
  id                      String       @id @default(uuid())
  fullName                String
  dateOfBirth             DateTime
  gender                  Gender
  address                 String
  placeOfBirth            String
  birthWeight             Float?
  numberOfSiblings        Int?
  caregiverId             String
  caregiver               CareGiver    @relation(fields: [caregiverId], references: [id], onDelete: Cascade)
  relationToCaregiver     Relationship
  householdSize           Int
  schoolEnrollmentStatus  Boolean      @default(false) @map("schoolEnrollmmentStatus")
  typeOfSchool            SchoolType?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinicalAssessments       ClinicalAssessment[]
  clinicalReferrals         ClinicalReferral[]
  rehabTasks                RehabTask[]
  functionalClassifications FunctionalClassification[]

  appointments Appointment[]

  @@map("cpPatient")
  @@index([caregiverId])
}

model FunctionalClassification {
  id        String   @id @default(uuid())
  patientId String
  patient   CpPatient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  classifier String
  level      Int
  assessedAt DateTime

  assessorId String?
  assessor   ServiceProvider? @relation(fields: [assessorId], references: [id])

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId])
  @@index([assessorId])
}

model ClinicalAssessment {
  id        String   @id @default(uuid())
  patientId String
  patient   CpPatient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  providerId String
  provider   ServiceProvider @relation("ProviderAssessments", fields: [providerId], references: [id], onDelete: Cascade)

  toolCode    String
  toolVersion String
  status      AssessmentStatus @default(DRAFT)
  assessedAt  DateTime?
  responses   Json

  referralId String?           @unique
  referral   ClinicalReferral? @relation("ReferralAssessment", fields: [referralId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reports ClinicalAssessmentReport[]

  @@index([patientId])
  @@index([providerId])
}

model ClinicalAssessmentReport {
  id           String             @id @default(uuid())
  assessmentId String
  assessment   ClinicalAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  summary         String?
  scores          Json
  interpretation  String?
  recommendations Json?

  createdAt DateTime @default(now())

  @@index([assessmentId])
}

model ClinicalReferral {
  id        String   @id @default(uuid())
  patientId String
  patient   CpPatient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  fromProviderId String
  fromProvider   ServiceProvider  @relation("ProviderReferrals", fields: [fromProviderId], references: [id], onDelete: Cascade)
  toProviderId   String?
  toProvider     ServiceProvider? @relation("ReferralRecipients", fields: [toProviderId], references: [id], onDelete: SetNull)

  toProfession Profession
  reason       String

  relatedAssessment ClinicalAssessment? @relation("ReferralAssessment")

  status    ReferralStatus @default(PENDING)
  createdAt DateTime       @default(now())

  generatedTasks RehabTask[]

  @@index([patientId])
  @@index([fromProviderId])
  @@index([toProviderId])
}

model RehabTask {
  id        String   @id @default(uuid())
  patientId String
  patient   CpPatient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  providerId String
  provider   ServiceProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  title            String
  instructions     String
  instructionSteps Json?
  frequencyPerDay  Int?
  frequencyNote    String?
  durationDays     Int
  startDate        DateTime?
  endDate          DateTime?
  videoUrl         String?
  progress         Int       @default(0)
  completedDates   String[]  @default([])

  status                RehabTaskStatus @default(PENDING)
  completedAt           DateTime?
  caregiverMarkedDoneAt DateTime?

  referralId String?
  referral   ClinicalReferral? @relation(fields: [referralId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId])
  @@index([providerId])
  @@index([referralId])
}

model Appointment {
  id        String   @id @default(uuid())
  patientId String
  patient   CpPatient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  providerId String
  provider   ServiceProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  appointmentDate DateTime
  reasonText      String?
  reasonAudio     String?

  status    AppointmentStatus @default(PENDING)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([patientId])
  @@index([providerId])
}

model AssessmentTool {
  id          String   @id @default(uuid())
  toolCode    String   @unique
  toolName    String
  version     String
  description String?
  schema      Json?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  professions AssessmentToolProfession[]
}

model AssessmentToolProfession {
  id         String         @id @default(uuid())
  toolId     String
  tool       AssessmentTool @relation(fields: [toolId], references: [id], onDelete: Cascade)
  profession Profession
  createdAt  DateTime       @default(now())

  @@unique([toolId, profession])
}

model VideoCache {
  id         String   @id @default(uuid())
  cacheKey   String   @unique // e.g., "youtube_channel_videos"
  cachedData Json // Stores the entire response from YouTube API
  pageInfo   Json? // Stores pagination info
  lastFetch  DateTime @default(now())
  ttl        Int      @default(3600) // Time to live in seconds (default: 1 hour)
  isValid    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ==================== COMMUNITY MODELS ====================

enum CommunityMemberRole {
  OWNER
  ADMIN
  MEMBER
}

enum CommunityMemberStatus {
  ACTIVE
  PENDING
  BANNED
  LEFT
}

enum GroupMemberRole {
  ADMIN
  MEMBER
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  LOCATION
}

enum DirectMessageStatus {
  SENT
  DELIVERED
  READ
}

enum NotificationType {
  IN_APP
  PUSH
}

enum NotificationCategory {
  DIRECT_MESSAGE
  COMMUNITY_MESSAGE
  COMMUNITY_ANNOUNCEMENT
  APPOINTMENT_REMINDER
  TASK_REMINDER
  SYSTEM
}

enum NotificationStatus {
  UNREAD
  READ
  ARCHIVED
}

enum AccountStatus {
  ACTIVE
  DEACTIVATED
  DELETED
}

model Community {
  id          String  @id @default(uuid())
  name        String
  description String?
  image       String?
  createdBy   String
  creator     User    @relation("CommunityCreator", fields: [createdBy], references: [id], onDelete: Cascade)

  inviteCode    String? @unique
  inviteEnabled Boolean @default(true)
  maxMembers    Int     @default(1000)
  isPublic      Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members       CommunityMember[]
  groups        CommunityGroup[]
  announcements CommunityAnnouncement[]
  invitations   CommunityInvitation[]

  @@index([createdBy])
  @@index([inviteCode])
}

model CommunityMember {
  id          String                @id @default(uuid())
  communityId String
  community   Community             @relation(fields: [communityId], references: [id], onDelete: Cascade)
  userId      String
  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        CommunityMemberRole   @default(MEMBER)
  status      CommunityMemberStatus @default(ACTIVE)
  joinedAt    DateTime              @default(now())
  invitedBy   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([communityId, userId])
  @@index([userId])
  @@index([communityId, status])
}

model CommunityGroup {
  id          String    @id @default(uuid())
  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  name        String
  description String?
  image       String?
  createdBy   String

  isDefault          Boolean @default(false)
  isAnnouncementOnly Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members  CommunityGroupMember[]
  messages CommunityMessage[]

  @@index([communityId])
  @@index([createdBy])
}

model CommunityGroupMember {
  id       String          @id @default(uuid())
  groupId  String
  group    CommunityGroup  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId   String
  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     GroupMemberRole @default(MEMBER)
  joinedAt DateTime        @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([groupId, userId])
  @@index([userId])
}

model CommunityMessage {
  id        String             @id @default(uuid())
  groupId   String
  group     CommunityGroup     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User               @relation(fields: [senderId], references: [id], onDelete: Cascade)
  content   String?
  type      MessageType        @default(TEXT)
  mediaUrl  String?
  caption   String?            // Caption for media messages
  metadata  Json?
  status    MessageStatus      @default(SENT)
  replyToId String?
  replyTo   CommunityMessage?  @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies   CommunityMessage[] @relation("MessageReplies")
  likes     Int                @default(0)
  dislikes  Int                @default(0)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@index([groupId])
  @@index([senderId])
  @@index([createdAt])
}

model CommunityAnnouncement {
  id          String    @id @default(uuid())
  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  title       String
  content     String
  mediaUrl    String?
  caption     String?           // Caption for media content
  createdBy   String
  creator     User      @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  isPinned    Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([communityId])
  @@index([createdBy])
}

model CommunityInvitation {
  id          String    @id @default(uuid())
  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  invitedBy   String
  inviter     User      @relation(fields: [invitedBy], references: [id], onDelete: Cascade)
  invitedUser String?
  phoneNumber String?
  email       String?
  code        String    @unique
  expiresAt   DateTime
  usedAt      DateTime?

  createdAt DateTime @default(now())

  @@index([communityId])
  @@index([code])
  @@index([invitedBy])
}

model PdfResource {
  id                String          @id @default(uuid())
  title             String
  description       String?
  pdfFile           String[]
  serviceProviderId String
  serviceProvider   ServiceProvider @relation(fields: [serviceProviderId], references: [id], onDelete: Cascade)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  user              User?           @relation(fields: [userId], references: [id])
  userId            String?

  @@map("pdfResource")
  @@index([serviceProviderId])
}

// Notification models
model Notification {
  id           String               @id @default(uuid())
  userId       String
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         NotificationType
  category     NotificationCategory
  title        String
  content      String?
  data         Json? // Additional data specific to notification type
  status       NotificationStatus   @default(UNREAD)
  relatedId    String? // ID of related entity (messageId, announcementId, etc.)
  relatedModel String? // Model name of related entity
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  expiresAt    DateTime? // For time-sensitive notifications

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([type, category])
}

// Push notification tokens (for mobile/web push)
model PushNotificationToken {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade, name: "UserPushTokens")
  token      String   @unique
  deviceType String // ios, android, web
  deviceId   String? // Device identifier
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
  @@index([token])
  @@index([isActive])
}

// Direct messaging models
model DirectMessage {
  id         String              @id @default(uuid())
  senderId   String
  sender     User                @relation(fields: [senderId], references: [id], onDelete: Cascade, name: "DirectMessageSender")
  receiverId String
  receiver   User                @relation(fields: [receiverId], references: [id], onDelete: Cascade, name: "DirectMessageReceiver")
  content    String?
  mediaUrl   String?
  caption    String?             // Caption for media messages
  type       MessageType         @default(TEXT)
  status     DirectMessageStatus @default(SENT)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  @@map("directMessage")
  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
  @@index([senderId, receiverId])
}
