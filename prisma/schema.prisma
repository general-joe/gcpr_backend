generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Gender {
  MALE
  FEMALE
}

enum Relationship {
  PARENT
  GUARDIAN
  SIBLING
  OTHER
}

enum Role {
  SERVICE_PROVIDER
  CAREGIVER
}

enum CaregiverType {
  GROUP
  INDIVIDUAL
}

enum LicenseStatus {
  ACTIVE
  INACTIVE
}

enum EducationLevel {
  BASIC
  HIGHSCHOOL
  TERTIARY
}

enum IdType {
  NATIONAL_ID
  PASSPORT
  DRIVER_LICENSE
  ECOWAS_ID
}

enum schoolType {
  PUBLIC
  PRIVATE
  SPECIAL_NEEDS
}

enum Profession {
  GENERAL_PAEDIATRICIAN
  DEVELOPMENTAL_PAEDIATRICIAN
  PAEDIATRIC_NEUROLOGIST
  NEURODEVELOPMENTAL_PAEDIATRICIAN
  REHABILITATION_PAEDIATRICIAN
  PHYSIOTHERAPIST
  OCCUPATIONAL_THERAPIST
  SPEECH_THERAPIST
  CLINICAL_PSYCHOLOGIST
  DIETITIAN
  PHARMACIST
}

enum FacilityType {
  TERTIARY_TEACHING_HOSPITAL
  REGIONAL_HOSPITAL
  SECONDARY_HEALTH_CARE
  PRIMARY_HEALTHCARE
  CP_HOME
}

enum ProfessionalBody {
  AHPC
  MDC
  PHCG
  PSCG
}

enum AssessmentStatus {
  DRAFT
  COMPLETED
  REVIEWED
}

enum ReferralStatus {
  PENDING
  ACCEPTED
  DECLINED
  COMPLETED
}

enum RehabTaskStatus {
  PENDING
  ASSIGNED
  COMPLETED
}

enum appointmentStatus {
  PENDING
  APPROVED
  DECLINED
  COMPLETED
}

model User {
  id                  String               @id @default(uuid())
  fullName            String
  email               String?              @unique
  password            String
  phoneNumber         String               @unique
  gender              Gender
  role                Role
  profileImage        String?
  verified            Boolean              @default(false)
  profileCompleted    Boolean              @default(false)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  address             String?
  digitalAddress      String?
  dateOfBirth         DateTime
  otp                 Otp?
  refreshToken        RefreshToken[]
  passwordResetTokens PasswordResetToken[]

  serviceProvider serviceProvider?
  caregiver       CareGiver?
}

model Otp {
  id         String    @id @default(uuid())
  codeHash   String?
  userId     String    @unique
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime?
  attempts   Int       @default(0)
  requestId  String?
  prefix     String?
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  expiresAt DateTime
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  expiresAt DateTime
  usedAt    DateTime?
}

model serviceProvider {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  licenseNumber     String?
  licenseImage      String?
  licenseExpiry     DateTime
  licenseIssuedBy   String?
  licenseIssuedDate DateTime
  licenseType       ProfessionalBody
  licenseStatus     LicenseStatus    @default(INACTIVE)
  profession        Profession
  facilityType      FacilityType
  facilityName      String
  facilityAddress   String
  licensePin        String
  experience        Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinicalAssessments       ClinicalAssessment[]       @relation("ProviderAssessments")
  clinicalReferrals         ClinicalReferral[]         @relation("ProviderReferrals")
  incomingReferrals         ClinicalReferral[]         @relation("ReferralRecipients")
  rehabTasks                RehabTask[]
  functionalClassifications FunctionalClassification[]

  appointments   Appointment[]
  availabilities ProviderAvailability[]
}

model ProviderAvailability {
  id         String          @id @default(uuid())
  providerId String
  provider   serviceProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  dayOfWeek Int // 0 = Sunday, 1 = Monday ... 6 = Saturday
  startTime String // stored as HH:mm
  endTime   String // stored as HH:mm

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([providerId])
}

model CareGiver {
  id     String        @id @default(uuid())
  type   CaregiverType
  userId String?       @unique
  user   User?         @relation(fields: [userId], references: [id], onDelete: Cascade)

  occupation     String?
  educationLevel EducationLevel?
  idType         IdType?
  idNumber       String?

  nameOfGroup           String?
  locationOfGroup       String?
  groupContact          String?
  groupDigitalAddress   String?
  groupEmail            String?
  ManagerName           String?
  managerContact        String?
  verificationDocuments String[]
  isVerified            Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cpPatients cpPatient[]
}

model cpPatient {
  id                      String       @id @default(uuid())
  fullName                String
  dateOfBirth             DateTime
  age                     Int
  gender                  Gender
  address                 String
  placeOfBirth            String
  birthWeight             Float?
  numberOfSiblings        Int?
  caregiverId             String
  caregiver               CareGiver    @relation(fields: [caregiverId], references: [id], onDelete: Cascade)
  relationToCaregiver     Relationship
  householdSize           Int
  schoolEnrollmmentStatus Boolean      @default(false)
  typeOfSchool            schoolType?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinicalAssessments       ClinicalAssessment[]
  clinicalReferrals         ClinicalReferral[]
  rehabTasks                RehabTask[]
  functionalClassifications FunctionalClassification[]

  appointments Appointment[]
}

model FunctionalClassification {
  id        String    @id @default(uuid())
  patientId String
  patient   cpPatient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  classifier String
  level      Int
  assessedAt DateTime

  assessorId String?
  assessor   serviceProvider? @relation(fields: [assessorId], references: [id])

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ClinicalAssessment {
  id        String    @id @default(uuid())
  patientId String
  patient   cpPatient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  providerId String
  provider   serviceProvider @relation("ProviderAssessments", fields: [providerId], references: [id], onDelete: Cascade)

  toolCode    String
  toolVersion String
  status      AssessmentStatus @default(DRAFT)
  assessedAt  DateTime?
  responses   Json

  referralId String?           @unique
  referral   ClinicalReferral? @relation("ReferralAssessment", fields: [referralId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reports ClinicalAssessmentReport[]
}

model ClinicalAssessmentReport {
  id           String             @id @default(uuid())
  assessmentId String
  assessment   ClinicalAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  summary         String?
  scores          Json
  interpretation  String?
  recommendations Json?

  createdAt DateTime @default(now())
}

model ClinicalReferral {
  id        String    @id @default(uuid())
  patientId String
  patient   cpPatient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  fromProviderId String
  fromProvider   serviceProvider  @relation("ProviderReferrals", fields: [fromProviderId], references: [id], onDelete: Cascade)
  toProviderId   String?
  toProvider     serviceProvider? @relation("ReferralRecipients", fields: [toProviderId], references: [id], onDelete: SetNull)

  toProfession Profession
  reason       String

  relatedAssessment ClinicalAssessment? @relation("ReferralAssessment")

  status    ReferralStatus @default(PENDING)
  createdAt DateTime       @default(now())

  generatedTasks RehabTask[]

  @@index([toProviderId])
}

model RehabTask {
  id        String    @id @default(uuid())
  patientId String
  patient   cpPatient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  providerId String
  provider   serviceProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  title            String
  instructions     String
  instructionSteps Json?
  frequencyPerDay  Int?
  frequencyNote    String?
  durationDays     Int
  startDate        DateTime?
  endDate          DateTime?
  video            Json?
  progress         Int       @default(0)
  completedStepIndexes Int[] @default([])

  status      RehabTaskStatus @default(PENDING)
  completedAt DateTime?
  caregiverMarkedDoneAt DateTime?

  referralId String?
  referral   ClinicalReferral? @relation(fields: [referralId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Appointment {
  id        String    @id @default(uuid())
  patientId String
  patient   cpPatient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  providerId String
  provider   serviceProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  appointmentDate DateTime
  reason          String

  status    appointmentStatus @default(PENDING)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

model AssessmentTool {
  id          String   @id @default(uuid())
  toolCode    String   @unique
  toolName    String
  version     String
  description String?
  schema      Json?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  professions AssessmentToolProfession[]
}

model AssessmentToolProfession {
  id         String         @id @default(uuid())
  toolId     String
  tool       AssessmentTool @relation(fields: [toolId], references: [id], onDelete: Cascade)
  profession Profession
  createdAt  DateTime       @default(now())

  @@unique([toolId, profession])
}
