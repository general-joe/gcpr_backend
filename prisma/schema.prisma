// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Define your database models here and run `prisma migrate dev` to create migrations,
enum Gender {
  MALE
  FEMALE
}

enum Relationship {
  PARENT
  GUARDIAN
  SIBLING
  OTHER
}

enum Role {
  SERVICE_PROVIDER
  CAREGIVER
}

enum CaregiverType {
  GROUP
  INDIVIDUAL
}

enum LicenseStatus {
  ACTIVE
  INACTIVE
}

enum EducationLevel {
  BASIC
  HIGHSCHOOL
  TERTIARY
}

enum IdType {
  NATIONAL_ID
  PASSPORT
  DRIVER_LICENSE
  ECOWAS_ID
}

enum Profession {
  GENERAL_PAEDIATRICIAN
  DEVELOPMENTAL_PAEDIATRICIAN
  PAEDIATRIC_NEUROLOGIST
  NEURODEVELOPMENTAL_PAEDIATRICIAN
  REHABILITATION_PAEDIATRICIAN
  PHYSIOTHERAPIST
  OCCUPATIONAL_THERAPIST
  SPEECH_THERAPIST
  CLINICAL_PSYCHOLOGIST
  DIETITIAN
  PHARMACIST
}

enum FacilityType {
  TERTIARY_TEACHING_HOSPITAL
  REGIONAL_HOSPITAL
  SECONDARY_HEALTH_CARE
  PRIMARY_HEALTHCARE
  CP_HOME
}

enum ProfessionalBody {
  AHPC
  MDC
  PHCG
  PSCG
}

model User {
  id              String           @id @default(uuid())
  fullName        String
  email           String           @unique
  password        String
  dateOfBirth     DateTime?
  address         String?
  digitalAddress  String?
  phoneNumber     String
  gender          String
  role            Role
  profileImage    String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  otp             Otp?
  serviceProvider serviceProvider?
  caregiver       CareGiver?

  refreshToken        RefreshToken[]
  passwordResetTokens PasswordResetToken[]
}

model Otp {
  id         String    @id @default(uuid())
  codeHash   String
  userId     String    @unique
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  attempts   Int       @default(0) // increment per wrong attempt
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  expiresAt DateTime
}


model PasswordResetToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  expiresAt DateTime
  usedAt    DateTime? // optional to track if it has been used
}

model serviceProvider {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  licenseDetails    String[]
  licenseNumber     String?
  licenseImage      String?
  licenseExpiry     DateTime
  licenseIssuedBy   String?
  licenseIssuedDate DateTime
  licenseType       String
  licenseStatus     LicenseStatus @default(INACTIVE)
  profession        Profession
  facilityType      FacilityType
  facilityName      String
  facilityAddress   String

  experience Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model CareGiver {
  id     String        @id @default(uuid())
  type   CaregiverType
  userId String?       @unique // only set for INDIVIDUAL
  user   User?         @relation(fields: [userId], references: [id], onDelete: Cascade)

  // individual fields
  occupation     String?
  educationLevel EducationLevel?
  idType         IdType?
  idNumber       String?

  // group fields
  nameOfGroup           String?
  locationOfGroup       String?
  groupContact          String?
  groupDigitalAddress   String?
  groupEmail            String?
  ManagerName           String?
  managerContact        String?
  verificationDocuments String[]
  isVerified            Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cpPatients cpPatient[]
}

model cpPatient {
  id                      String       @id @default(uuid())
  fullName                String
  dateOfBirth             DateTime
  age                     Int
  gender                  Gender
  address                 String
  placeOfBirth            String
  birthWeight             Float?
  numberOfSiblings        Int?
  caregiverId             String
  caregiver               CareGiver    @relation(fields: [caregiverId], references: [id], onDelete: Cascade)
  relationToCaregiver     Relationship
  householdSize           Int
  schoolEnrollmmentStatus Boolean      @default(false)
  typeOfSchool            String?
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt
}
