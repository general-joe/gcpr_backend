// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
    
 
}

datasource db {
  provider = "postgresql"
}

// Define your database models here and run `prisma migrate dev` to create migrations,
enum Role {
  SERVICE_PROVIDER
  CAREGIVER
  INDIVIDUAL
}

model User {
  id           String   @id @default(uuid())
  fullName     String
  email        String   @unique
  password     String
  dateOfBirth  DateTime?
  address      String
  phoneNumber  String
  idVerification String
  gender       String
  age          Int
  role         Role
  isVerified   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  otp          OTP?
}

model OTP {
  id        String   @id @default(uuid())
  code      String
  expiresAt DateTime
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}


