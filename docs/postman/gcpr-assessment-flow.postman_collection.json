{
  "info": {
    "name": "GCPR Assessment + Referral Flow",
    "description": "End-to-end flow: auth, profile completion, patient, assessment submission, referral creation, referral acceptance, task assignment, and task progress update.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Auth - Provider A Login (Physio)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"identifier\": \"{{providerAIdentifier}}\",\n  \"password\": \"{{providerAPassword}}\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const res = pm.response.json();",
              "if (res?.data?.accessToken) pm.environment.set('providerAToken', res.data.accessToken);",
              "if (res?.data?.user?.serviceProvider?.id) pm.environment.set('providerAServiceProviderId', res.data.user.serviceProvider.id);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "2. Auth - Provider B Login (Target Provider)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"identifier\": \"{{providerBIdentifier}}\",\n  \"password\": \"{{providerBPassword}}\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const res = pm.response.json();",
              "if (res?.data?.accessToken) pm.environment.set('providerBToken', res.data.accessToken);",
              "if (res?.data?.user?.serviceProvider?.id) pm.environment.set('providerBServiceProviderId', res.data.user.serviceProvider.id);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "3. Auth - Caregiver Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"identifier\": \"{{caregiverIdentifier}}\",\n  \"password\": \"{{caregiverPassword}}\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const res = pm.response.json();",
              "if (res?.data?.accessToken) pm.environment.set('caregiverToken', res.data.accessToken);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "4. CP Patient - Create",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{caregiverToken}}"
          }
        ],
        "url": "{{baseUrl}}/cp-patient",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"fullName\": \"Test Child One\",\n  \"dateOfBirth\": \"2020-01-20\",\n  \"gender\": \"MALE\",\n  \"address\": \"Accra\",\n  \"placeOfBirth\": \"Accra\",\n  \"birthWeight\": 2.8,\n  \"numberOfSiblings\": 1,\n  \"relationToCaregiver\": \"PARENT\",\n  \"householdSize\": 4,\n  \"schoolEnrollmmentStatus\": false\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const res = pm.response.json();",
              "if (res?.data?.id) pm.environment.set('patientId', res.data.id);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "5. Assessment - Get Tools (Provider A)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{providerAToken}}"
          }
        ],
        "url": "{{baseUrl}}/assessment/tools"
      }
    },
    {
      "name": "6. Assessment - Get Form by Tool Code (GMFM_88) (Provider A)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{providerAToken}}"
          }
        ],
        "url": "{{baseUrl}}/assessment/tools/GMFM_88/form"
      }
    },
    {
      "name": "7. Assessment - Submit GMFM (Provider A)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{providerAToken}}"
          }
        ],
        "url": "{{baseUrl}}/assessment/submit",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"patientId\": \"{{patientId}}\",\n  \"toolCode\": \"GMFM_88\",\n  \"status\": \"COMPLETED\",\n  \"responses\": {\n    \"A1\": 3,\n    \"A2\": 3,\n    \"A3\": 3,\n    \"A4\": 3,\n    \"A5\": 3,\n    \"A6\": 2,\n    \"A7\": 2,\n    \"A8\": 2,\n    \"A9\": 2,\n    \"A10\": 2,\n    \"A11\": 2,\n    \"A12\": 2,\n    \"A13\": 2,\n    \"A14\": 2,\n    \"A15\": 2,\n    \"A16\": 2,\n    \"A17\": 2,\n    \"B18\": 2,\n    \"B19\": 2,\n    \"B20\": 2,\n    \"B21\": 2,\n    \"B22\": 2,\n    \"B23\": 2,\n    \"B24\": 2,\n    \"B25\": 2,\n    \"B26\": 2,\n    \"B27\": 2,\n    \"B28\": 2,\n    \"B29\": 2,\n    \"B30\": 2,\n    \"B31\": 2,\n    \"B32\": 2,\n    \"B33\": 2,\n    \"B34\": 2,\n    \"B35\": 2,\n    \"B36\": 2,\n    \"B37\": 2,\n    \"C38\": 2,\n    \"C39\": 2,\n    \"C40\": 2,\n    \"C41\": 2,\n    \"C42\": 2,\n    \"C43\": 2,\n    \"C44\": 2,\n    \"C45\": 2,\n    \"C46\": 2,\n    \"C47\": 2,\n    \"C48\": 2,\n    \"C49\": 2,\n    \"C50\": 2,\n    \"C51\": 2,\n    \"D52\": 1,\n    \"D53\": 1,\n    \"D54\": 1,\n    \"D55\": 1,\n    \"D56\": 1,\n    \"D57\": 1,\n    \"D58\": 1,\n    \"D59\": 1,\n    \"D60\": 1,\n    \"D61\": 1,\n    \"D62\": 1,\n    \"D63\": 1,\n    \"D64\": 1,\n    \"E65\": 1,\n    \"E66\": 1,\n    \"E67\": 1,\n    \"E68\": 1,\n    \"E69\": 1,\n    \"E70\": 1,\n    \"E71\": 1,\n    \"E72\": 1,\n    \"E73\": 1,\n    \"E74\": 1,\n    \"E75\": 1,\n    \"E76\": 1,\n    \"E77\": 1,\n    \"E78\": 1,\n    \"E79\": 1,\n    \"E80\": 1,\n    \"E81\": 1,\n    \"E82\": 1,\n    \"E83\": 1,\n    \"E84\": 1,\n    \"E85\": 1,\n    \"E86\": 1,\n    \"E87\": 1,\n    \"E88\": 1\n  }\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const res = pm.response.json();",
              "if (res?.data?.assessment?.id) pm.environment.set('assessmentId', res.data.assessment.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "8. Referral - Create (Provider A)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{providerAToken}}"
          }
        ],
        "url": "{{baseUrl}}/assessment/referrals",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"patientId\": \"{{patientId}}\",\n  \"assessmentId\": \"{{assessmentId}}\",\n  \"toProfession\": \"OCCUPATIONAL_THERAPIST\",\n  \"toProviderId\": \"{{providerBServiceProviderId}}\",\n  \"reason\": \"Needs OT intervention for fine motor and ADL training\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const res = pm.response.json();",
              "if (res?.data?.id) pm.environment.set('referralId', res.data.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "9. Referrals - Incoming (Provider B)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{providerBToken}}"
          }
        ],
        "url": "{{baseUrl}}/assessment/referrals/incoming"
      }
    },
    {
      "name": "10. Referral - Accept (Provider B)",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{providerBToken}}"
          }
        ],
        "url": "{{baseUrl}}/assessment/referrals/{{referralId}}/status",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"ACCEPTED\"\n}"
        }
      }
    },
    {
      "name": "11. Rehab Task - Create from Referral (Provider B)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{providerBToken}}"
          }
        ],
        "url": "{{baseUrl}}/assessment/referrals/{{referralId}}/tasks",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Daily trunk balance training\",\n  \"instructions\": \"Perform seated trunk reaches with caregiver support\",\n  \"instructionSteps\": [\"Sit upright\", \"Reach for toy\", \"Return to center\"],\n  \"frequencyPerDay\": 2,\n  \"frequencyNote\": \"Morning and evening\",\n  \"durationDays\": 21\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const res = pm.response.json();",
              "if (res?.data?.id) pm.environment.set('taskId', res.data.id);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "12. Task - Update Progress (Provider B)",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{providerBToken}}"
          }
        ],
        "url": "{{baseUrl}}/assessment/tasks/{{taskId}}/progress",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"progress\": {{taskProgress}}\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const res = pm.response.json();",
              "if (res?.data?.progress !== undefined) pm.environment.set('taskProgress', String(res.data.progress));"
            ]
          }
        }
      ]
    },
    {
      "name": "13. Tasks - My Assigned (Provider B)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{providerBToken}}"
          }
        ],
        "url": "{{baseUrl}}/assessment/tasks/my"
      }
    },
    {
      "name": "14. Caregiver - Mark Task Step Done",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{caregiverToken}}"
          }
        ],
        "url": "{{baseUrl}}/cp-patient/{{patientId}}/assigned-tasks/{{taskId}}/steps/done",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"stepIndex\": {{taskStepIndex}}\n}"
        }
      }
    },
    {
      "name": "15. Caregiver - Mark Task Done",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{caregiverToken}}"
          }
        ],
        "url": "{{baseUrl}}/cp-patient/{{patientId}}/assigned-tasks/{{taskId}}/done"
      }
    },
    {
      "name": "16. Assessment Report by AssessmentId (Provider B)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{providerBToken}}"
          }
        ],
        "url": "{{baseUrl}}/assessment/{{assessmentId}}/report"
      }
    },
    {
      "name": "17. Assessment Reports by Patient (Provider A)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{providerAToken}}"
          }
        ],
        "url": "{{baseUrl}}/assessment/patient/{{patientId}}/reports"
      }
    },
    {
      "name": "18. Negative Test - Non-target Provider Accept Referral (should fail 403)",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{providerAToken}}"
          }
        ],
        "url": "{{baseUrl}}/assessment/referrals/{{referralId}}/status",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"COMPLETED\"\n}"
        }
      }
    }
  ],
