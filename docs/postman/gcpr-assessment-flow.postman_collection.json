{
  "info": {
    "name": "GCPR Assessment + Referral Flow",
    "description": "End-to-end flow: auth, profile completion, patient, assessment submission with referral, referral acceptance, task assignment.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Auth - Provider A Login (Physio)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"identifier\": \"{{providerAIdentifier}}\",\n  \"password\": \"{{providerAPassword}}\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const res = pm.response.json();",
              "if (res?.data?.accessToken) pm.environment.set('providerAToken', res.data.accessToken);",
              "if (res?.data?.user?.serviceProvider?.id) pm.environment.set('providerAServiceProviderId', res.data.user.serviceProvider.id);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "2. Auth - Provider B Login (Target Provider)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"identifier\": \"{{providerBIdentifier}}\",\n  \"password\": \"{{providerBPassword}}\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const res = pm.response.json();",
              "if (res?.data?.accessToken) pm.environment.set('providerBToken', res.data.accessToken);",
              "if (res?.data?.user?.serviceProvider?.id) pm.environment.set('providerBServiceProviderId', res.data.user.serviceProvider.id);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "3. Auth - Caregiver Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"identifier\": \"{{caregiverIdentifier}}\",\n  \"password\": \"{{caregiverPassword}}\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const res = pm.response.json();",
              "if (res?.data?.accessToken) pm.environment.set('caregiverToken', res.data.accessToken);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "4. CP Patient - Create",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{caregiverToken}}" }
        ],
        "url": "{{baseUrl}}/cp-patient",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"fullName\": \"Test Child One\",\n  \"dateOfBirth\": \"2020-01-20\",\n  \"gender\": \"MALE\",\n  \"address\": \"Accra\",\n  \"placeOfBirth\": \"Accra\",\n  \"birthWeight\": 2.8,\n  \"numberOfSiblings\": 1,\n  \"relationToCaregiver\": \"PARENT\",\n  \"householdSize\": 4,\n  \"schoolEnrollmmentStatus\": false\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const res = pm.response.json();",
              "if (res?.data?.id) pm.environment.set('patientId', res.data.id);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "5. Assessment - Submit GMFM + Referral (Provider A)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{providerAToken}}" }
        ],
        "url": "{{baseUrl}}/assessment/submit",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"patientId\": \"{{patientId}}\",\n  \"toolCode\": \"GMFM_88\",\n  \"status\": \"COMPLETED\",\n  \"responses\": {\n    \"A1\": 3, \"A2\": 3, \"A3\": 3, \"A4\": 3, \"A5\": 3, \"A6\": 2, \"A7\": 2, \"A8\": 2, \"A9\": 2, \"A10\": 2, \"A11\": 2, \"A12\": 2, \"A13\": 2, \"A14\": 2, \"A15\": 2, \"A16\": 2, \"A17\": 2,\n    \"B18\": 2, \"B19\": 2, \"B20\": 2, \"B21\": 2, \"B22\": 2, \"B23\": 2, \"B24\": 2, \"B25\": 2, \"B26\": 2, \"B27\": 2, \"B28\": 2, \"B29\": 2, \"B30\": 2, \"B31\": 2, \"B32\": 2, \"B33\": 2, \"B34\": 2, \"B35\": 2, \"B36\": 2, \"B37\": 2,\n    \"C38\": 2, \"C39\": 2, \"C40\": 2, \"C41\": 2, \"C42\": 2, \"C43\": 2, \"C44\": 2, \"C45\": 2, \"C46\": 2, \"C47\": 2, \"C48\": 2, \"C49\": 2, \"C50\": 2, \"C51\": 2,\n    \"D52\": 1, \"D53\": 1, \"D54\": 1, \"D55\": 1, \"D56\": 1, \"D57\": 1, \"D58\": 1, \"D59\": 1, \"D60\": 1, \"D61\": 1, \"D62\": 1, \"D63\": 1, \"D64\": 1,\n    \"E65\": 1, \"E66\": 1, \"E67\": 1, \"E68\": 1, \"E69\": 1, \"E70\": 1, \"E71\": 1, \"E72\": 1, \"E73\": 1, \"E74\": 1, \"E75\": 1, \"E76\": 1, \"E77\": 1, \"E78\": 1, \"E79\": 1, \"E80\": 1, \"E81\": 1, \"E82\": 1, \"E83\": 1, \"E84\": 1, \"E85\": 1, \"E86\": 1, \"E87\": 1, \"E88\": 1\n  },\n  \"referral\": {\n    \"toProfession\": \"OCCUPATIONAL_THERAPIST\",\n    \"toProviderId\": \"{{providerBServiceProviderId}}\",\n    \"reason\": \"Needs OT intervention for fine motor and ADL training\"\n  }\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const res = pm.response.json();",
              "if (res?.data?.assessment?.id) pm.environment.set('assessmentId', res.data.assessment.id);",
              "if (res?.data?.referral?.id) pm.environment.set('referralId', res.data.referral.id);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "6. Referrals - Incoming (Provider B)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{providerBToken}}" }],
        "url": "{{baseUrl}}/assessment/referrals/incoming"
      }
    },
    {
      "name": "7. Referral - Accept (Provider B)",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{providerBToken}}" }
        ],
        "url": "{{baseUrl}}/assessment/referrals/{{referralId}}/status",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"ACCEPTED\"\n}"
        }
      }
    },
    {
      "name": "8. Rehab Task - Create from Referral (Provider B)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{providerBToken}}" }
        ],
        "url": "{{baseUrl}}/assessment/referrals/{{referralId}}/tasks",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Daily trunk balance training\",\n  \"instructions\": \"Perform seated trunk reaches with caregiver support\",\n  \"instructionSteps\": [\"Sit upright\", \"Reach for toy\", \"Return to center\"],\n  \"frequencyPerDay\": 2,\n  \"frequencyNote\": \"Morning and evening\",\n  \"durationDays\": 21\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const res = pm.response.json();",
              "if (res?.data?.id) pm.environment.set('taskId', res.data.id);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "9. Tasks - My Assigned (Provider B)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{providerBToken}}" }],
        "url": "{{baseUrl}}/assessment/tasks/my"
      }
    },
    {
      "name": "10. Assessment Report by AssessmentId (Provider B)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{providerBToken}}" }],
        "url": "{{baseUrl}}/assessment/{{assessmentId}}/report"
      }
    },
    {
      "name": "11. Assessment Reports by Patient (Provider A)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{providerAToken}}" }],
        "url": "{{baseUrl}}/assessment/patient/{{patientId}}/reports"
      }
    },
    {
      "name": "12. Negative Test - Non-target Provider Accept Referral (should fail 403)",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{providerAToken}}" }
        ],
        "url": "{{baseUrl}}/assessment/referrals/{{referralId}}/status",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"COMPLETED\"\n}"
        }
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "providerAIdentifier", "value": "" },
    { "key": "providerAPassword", "value": "" },
    { "key": "providerBIdentifier", "value": "" },
    { "key": "providerBPassword", "value": "" },
    { "key": "caregiverIdentifier", "value": "" },
    { "key": "caregiverPassword", "value": "" },
    { "key": "providerAToken", "value": "" },
    { "key": "providerBToken", "value": "" },
    { "key": "caregiverToken", "value": "" },
    { "key": "providerAServiceProviderId", "value": "" },
    { "key": "providerBServiceProviderId", "value": "" },
    { "key": "patientId", "value": "" },
    { "key": "assessmentId", "value": "" },
    { "key": "referralId", "value": "" },
    { "key": "taskId", "value": "" }
  ]
}
