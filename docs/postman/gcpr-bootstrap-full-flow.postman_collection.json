            ],
            "url": "{{baseUrl}}/auth/verify-otp",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"{{providerAEmail}}\",\n  \"otp\": \"{{providerAOtp}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res=pm.response.json(); if(res?.data?.accessToken) pm.environment.set('providerAToken', res.data.accessToken);"
                ]
              }
            }
          ]
        },
        {
          "name": "A3 Login Provider A",
